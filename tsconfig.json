{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "declaration": false,
    "sourceMap": false,
    "types": ["node"],
    "paths": {
      "@openfde/ontology": ["./packages/ontology/src/index.ts"],
      "@openfde/core": ["./packages/core/src/index.ts"],
      "@openfde/webui": ["./packages/webui/src/index.ts"]
    }
  },
  "include": ["packages/*/src/**/*.ts", "packages/*/test/**/*.ts", "apps/*/src/**/*.ts"]
}
